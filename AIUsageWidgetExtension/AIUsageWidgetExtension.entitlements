<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.temporary-exception.files.home-relative-path.read-only</key>
	<array>
		<string>/.codex/</string>
		<string>/.codex/history.jsonl</string>
		<string>/.codex/session_index.jsonl</string>
		<string>/.codex/sessions/</string>
		<string>/.gemini/antigravity-cli/</string>
		<string>/.gemini/antigravity-cli/history.jsonl</string>
		<string>/.gemini/antigravity-cli/brain/</string>
	</array>
</dict>
</plist>
